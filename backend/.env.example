# vLLM Endpoints - 3 separate replicas
# Local development
VLLM_REPLICA_1_URL=http://localhost:8001/v1
VLLM_REPLICA_2_URL=http://localhost:8002/v1
VLLM_REPLICA_3_URL=http://localhost:8003/v1

# OpenShift deployment (uncomment and update namespace)
# VLLM_REPLICA_1_URL=http://vllm-replica-1.NAMESPACE.svc.cluster.local:8000/v1
# VLLM_REPLICA_2_URL=http://vllm-replica-2.NAMESPACE.svc.cluster.local:8000/v1
# VLLM_REPLICA_3_URL=http://vllm-replica-3.NAMESPACE.svc.cluster.local:8000/v1

# Model
MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct

# LLM-D Integration (future)
LLMD_ENABLED=false
LLMD_ROUTER_URL=http://llmd-router:8080
